# Timezone (IANA name, e.g. Europe/Moscow, America/New_York)
TZ=UTC

# ── Telegram ────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID — enables proactive messaging.
# DM @userinfobot and send /start to get it.
PRIMARY_USER_CHAT_ID=

# ── LLM Provider (OpenRouter) ───────────────────────────────
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=
# Fast model: cheap — classification, yes/no, emotion detection
LLM_FAST_MODEL=
# Smart model: expensive — message composition, reasoning
LLM_SMART_MODEL=
# Model used by the Motor Cortex agentic runtime
LLM_MOTOR_MODEL=
# Optional: app name reported to OpenRouter
LLM_APP_NAME=lifemodel

# ── Local / self-hosted model (OpenAI-compatible) ───────────
# Supports LM Studio, Ollama, LocalAI, vLLM, etc.
LLM_LOCAL_BASE_URL=
LLM_LOCAL_MODEL=
# Use the local model for the fast role (classification)
LLM_LOCAL_USE_FOR_FAST=false
# Use the local model for the smart role (reasoning) — usually keep false
LLM_LOCAL_USE_FOR_SMART=false
# Use the local model for the motor role
LLM_LOCAL_USE_FOR_MOTOR=false

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── Web search (optional) ───────────────────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=
# Provider fallback order, e.g. serper,tavily
SEARCH_PROVIDER_PRIORITY=
